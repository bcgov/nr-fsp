{
	# Disable the admin API (not needed in a container)
	admin off

	# Caddy defaults to :443/:80; override to run unprivileged
	http_port  2015
	https_port 8443
}

:2015 {
	root * /srv

	# Serve static files; fall back to index.html for React Router
	try_files {path} /index.html
	file_server

	# Health-check endpoint for OpenShift liveness/readiness probes
	handle /healthz {
		respond "OK" 200
	}

	# Aggressive caching for content-hashed assets (CRA adds hashes)
	@hashed {
		path_regexp \.[0-9a-f]{8}\.(js|css|woff2?)$
	}
	header @hashed Cache-Control "public, max-age=31536000, immutable"

	# Security headers
	header {
		X-Frame-Options        SAMEORIGIN
		X-Content-Type-Options nosniff
		Referrer-Policy        strict-origin-when-cross-origin
		-Server
	}

	encode zstd gzip
}
